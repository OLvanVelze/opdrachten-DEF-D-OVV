    "def draadlengte(V, I, r, rho):\n",
    "    A1 = np.pi * r**2\n",
    "    R = V/I\n",
    "    print(f\"Lengte van de draad: {A1 * R / rho:.2f} m\")\n",
    "    return (A1 * R) / (rho)\n",
    "\n",
    "test = draadlengte(9, 0.5, 0.1*1e-3, 1.68*1e-8)"
